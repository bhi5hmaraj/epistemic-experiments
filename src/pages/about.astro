---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/site";

const page = await getEntry("pages", "about");

if (!page) {
  throw new Error("Missing about page content.");
}

const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <div class="page page-narrow">
    <p class="eyebrow">About the community</p>
    <h1 class="page-title">{page.data.title}</h1>
    {page.data.subtitle && <p class="subtitle">{page.data.subtitle}</p>}
    <img
      class="page-cover"
      src={withBase("/images/inquiry-garden.webp")}
      alt="A watercolor vessel whose branching plant connects small islands of growth."
      loading="lazy"
    />
    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>
