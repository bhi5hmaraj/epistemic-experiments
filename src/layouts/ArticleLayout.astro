---
import BaseLayout from "./BaseLayout.astro";
import HypothesisComments from "../components/HypothesisComments.astro";
import TagList from "../components/TagList.astro";
import { formatDate, withBase } from "../lib/site";

interface Props {
  title: string;
  subtitle?: string;
  date: string;
  topics?: string[];
  coverImage?: string;
  privacyLevel?: "normal" | "sensitive";
  comments?: boolean;
  author?: string;
}

const {
  title,
  subtitle,
  date,
  topics = [],
  coverImage,
  privacyLevel = "normal",
  comments = false,
  author,
} = Astro.props;

const showComments = comments && privacyLevel !== "sensitive";
---

<BaseLayout
  title={title}
  description={subtitle}
  type="article"
  publishedDate={date}
  image={coverImage}
  author={author}
>
  <article class="article">
    <p class="eyebrow">Experiment Log</p>
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    <p class="meta">{formatDate(date)}</p>
    <TagList topics={topics} />
    {
      coverImage && (
        <img class="article__cover" src={withBase(coverImage)} alt="" />
      )
    }
    {
      privacyLevel === "sensitive" && (
        <p class="privacy-note">
          This log is a high-level summary. Personal questions and participant
          details are intentionally omitted.
        </p>
      )
    }
    <div class="article-content">
      <slot />
    </div>
    {showComments && <HypothesisComments />}
  </article>
</BaseLayout>
