---
import { absoluteUrl, site } from "../lib/site";

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  publishedDate?: string;
  author?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = "/images/og-default.jpg",
  imageAlt = "Epistemic Experiments — a field guide for shared inquiry.",
  type = "website",
  publishedDate,
  author,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const imageUrl = absoluteUrl(image);
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const isHome = Astro.url.pathname === basePath;

const structuredData: Record<string, unknown>[] = [];

if (type === "article" && publishedDate) {
  structuredData.push({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title.replace(` | ${site.name}`, ""),
    description,
    image: [imageUrl],
    datePublished: `${publishedDate}T00:00:00+05:30`,
    author: {
      "@type": /team|admin/i.test(author ?? "") ? "Organization" : "Person",
      name: author || site.name,
    },
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: Astro.site?.href,
    },
    mainEntityOfPage: canonical,
  });
}

if (isHome) {
  structuredData.push({
    "@context": "https://schema.org",
    "@type": "Organization",
    name: site.name,
    url: Astro.site?.href,
    logo: absoluteUrl("/icon-512.png"),
    description: site.description,
  });
}
---

<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex" />}
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={type} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={imageAlt} />
{type === "article" && publishedDate && (
  <meta property="article:published_time" content={`${publishedDate}T00:00:00+05:30`} />
)}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
{structuredData.map((data) => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />
))}
