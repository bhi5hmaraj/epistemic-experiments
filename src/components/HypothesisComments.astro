<section class="comments-panel" aria-labelledby="comments-title">
  <h2 id="comments-title">Comments</h2>
  <p>
    This page supports public annotation through Hypothesis. Turn it on, select
    any text, and choose Annotate. Sign in if prompted.
  </p>
  <button class="button-secondary" type="button" data-comments-enable>
    Turn on comments
  </button>
</section>

<dialog
  id="comment-dialog"
  class="comment-dialog"
  aria-labelledby="comment-dialog-title"
  data-comment-dialog
>
  <h2 id="comment-dialog-title">Comments are on</h2>
  <p>
    Select text on desktop, or long-press text on mobile, then choose Annotate
    in Hypothesis. Sign in if prompted.
  </p>
  <form method="dialog">
    <button class="button-secondary" type="submit">Got it</button>
  </form>
</dialog>

<script is:inline>
  (() => {
    const ENABLED_KEY = "hypothesis-enabled";
    const button = document.querySelector("[data-comments-enable]");
    const dialog = document.querySelector("[data-comment-dialog]");

    window.hypothesisConfig = function () {
      return {
        openSidebar: false,
        showHighlights: true,
      };
    };

    function markEnabled() {
      if (button instanceof HTMLButtonElement) {
        button.disabled = true;
        button.textContent = "Comments are on — select text to annotate";
      }
    }

    function loadHypothesis() {
      if (window.__hypothesisLoaded) {
        return;
      }

      window.__hypothesisLoaded = true;

      const script = document.createElement("script");
      script.src = "https://hypothes.is/embed.js";
      script.async = true;
      script.addEventListener("error", () => {
        window.__hypothesisLoaded = false;
        console.warn("Hypothesis comments could not be loaded.");
      });

      document.body.appendChild(script);
    }

    function showCommentDialog() {
      if (
        typeof HTMLDialogElement === "undefined" ||
        !(dialog instanceof HTMLDialogElement) ||
        dialog.open
      ) {
        return;
      }

      try {
        dialog.showModal();
      } catch {
        dialog.setAttribute("open", "");
      }
    }

    let enabled = false;
    try {
      enabled = sessionStorage.getItem(ENABLED_KEY) === "1";
    } catch {
      /* private browsing; comments stay opt-in per page */
    }

    if (enabled) {
      loadHypothesis();
      markEnabled();
    }

    button?.addEventListener("click", () => {
      try {
        sessionStorage.setItem(ENABLED_KEY, "1");
      } catch {
        /* private browsing; comments stay opt-in per page */
      }

      loadHypothesis();
      markEnabled();
      showCommentDialog();
    });
  })();
</script>
