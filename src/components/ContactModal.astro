<style>
  .contact-modal {
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--surface);
    color: var(--ink);
    padding: 0;
    max-width: 260px;
    width: 90vw;
    box-shadow: 0 8px 32px rgba(0,0,0,0.22);
  }

  .contact-modal::backdrop {
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(2px);
  }

  .contact-modal__inner {
    padding: 1.5rem 1.75rem 1.75rem;
    position: relative;
  }

  .contact-modal__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 0.85rem;
    line-height: 1;
    padding: 0.25rem 0.4rem;
  }

  .contact-modal__close:hover {
    color: var(--ink);
  }

  .contact-modal__label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin: 0 0 1.1rem;
  }

  .contact-modal__icons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .contact-modal__icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 10px;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--line);
    transition: background 0.15s, border-color 0.15s;
  }

  .contact-modal__icons a:hover {
    background: rgb(255 252 245 / 60%);
    border-color: var(--line-strong);
  }

  .contact-modal__icons svg {
    width: 1.05rem;
    height: 1.05rem;
  }
</style>
